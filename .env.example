# Anthropic API key used exclusively by the enrichment/scoring pipeline.
# Copy this file to .env and fill in your key. .env is git-ignored.
ANTHROPIC_API_KEY=

# Database
# SQLite (local dev, default):
DATABASE_URL=file:./dev.db

# PostgreSQL (production): change provider in prisma/schema.prisma to "postgresql", then:
# DATABASE_URL=postgresql://user:password@localhost:5432/hotbox_leads

# Claude model to use (default: claude-sonnet-4-6)
# CLAUDE_MODEL=claude-sonnet-4-6
