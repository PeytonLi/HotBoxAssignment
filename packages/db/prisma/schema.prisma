generator client {
  provider = "prisma-client-js"
}

datasource db {
  // SQLite for local dev. For PostgreSQL, change provider to "postgresql":
  //   postgresql://USER:PASS@HOST:5432/DBNAME
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// Pipeline output: one record per scored lead. Upserted by seed().
model LeadResult {
  username       String   @id
  qualityScore   Int
  summary        String
  tier           String   // Tier: "hot"|"strong"|"lukewarm"|"weak"|"spam" — indexed for filtering
  intentCategory String   // intentCategory from enrichmentInfo — indexed for filtering
  enrichmentInfo String   // Full JSON blob of EnrichmentInfo (kept for full fidelity reads)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([tier])
  @@index([intentCategory])
}

/// Operator triage decisions: one record per triaged lead.
model Triage {
  username  String   @id
  status    String   // TriageStatus: "unhandled" | "handled" | "dismissed"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

/// Content-hash cache for pipeline results. Keyed by sha256 of (lead JSON + prompt version).
model CacheEntry {
  key       String   @id
  value     String   // JSON-serialized LeadResult
  createdAt DateTime @default(now())
}
