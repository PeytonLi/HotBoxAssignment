{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "typecheck": {},
    "test": {},
    "test:e2e": {
      "cache": false
    },
    "pipeline": {
      "cache": false
    },
    "eval": {
      "cache": false
    }
  }
}
